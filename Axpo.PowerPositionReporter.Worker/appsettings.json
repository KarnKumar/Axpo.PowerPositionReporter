{
  "PowerPositionReporter": {
    "CsvReportPath": "C:\\Axpo\\report",
    "IntervalMinutes": 2,
    "MaxRetryAttempts": 3,
    "Logging": {
      "LogDirectory": "C:\\Axpo\\logs",
      "RetainedFileDays": 30,
      "OutputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff} {Level:u3}] {Message:lj}{NewLine}{Exception}"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Polly": "Error"
      }
    }
  }
}